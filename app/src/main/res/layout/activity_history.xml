<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".presentation.activity.HistoryActivity">

    <!-- Fixed Insights Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surface">

        <!-- Insights Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REACTOR INSIGHTS"
            android:textColor="@color/secondaryGlow"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="10dp" />

        <!-- Insights Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/bg_insights_card"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvTotalRecords"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Records: --"
                    android:textColor="@color/primaryEnergy"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvAvgLevel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avg Level: --%"
                    android:textColor="@color/primaryEnergy"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvChargingSessions"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Charging Sessions: --"
                    android:textColor="@color/primaryEnergy"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvMostCommonSource"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Common Source: --"
                    android:textColor="@color/primaryEnergy"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvHighestLevel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Highest: --%"
                    android:textColor="@color/success"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvLowestLevel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lowest: --%"
                    android:textColor="@color/warning"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAvgTemp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avg Temp: --°C"
                    android:textColor="@color/primaryEnergy"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvAvgVoltage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avg Voltage: --V"
                    android:textColor="@color/primaryEnergy"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Content Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- History List Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BATTERY EVENT LOG"
                android:textColor="@color/textSecondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No battery history recorded yet.\nBattery events will appear here."
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible"
                android:lineSpacingExtra="4dp" />

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBatteryHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="5"
                tools:listitem="@layout/item_battery_history" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/surface">

        <Button
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⚠ CLEAR ALL HISTORY"
            android:textColor="@color/warning"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_button_cyberpunk"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
