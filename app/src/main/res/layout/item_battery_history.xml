<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_card_cyberpunk"
    android:layout_marginBottom="8dp">

    <!-- Top Row: Timestamp + Charging State -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Jan 01, 00:00"
            android:textColor="@color/textSecondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            tools:text="Jun 03, 14:22" />

        <TextView
            android:id="@+id/tvChargingState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ IDLE"
            android:textColor="@color/textSecondary"
            android:textSize="10sp"
            android:fontFamily="monospace"
            tools:text="⚡ CHARGING" />
    </LinearLayout>

    <!-- Battery Level + Source Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Battery Level -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvBatteryLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textColor="@color/success"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                tools:text="85%" />
        </LinearLayout>

        <!-- Charging Source -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOURCE"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvChargingSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/primaryEnergy"
                android:textSize="13sp"
                android:fontFamily="monospace"
                tools:text="AC" />
        </LinearLayout>

        <!-- Temperature -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEMP"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvTemperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°C"
                android:textColor="@color/primaryEnergy"
                android:textSize="13sp"
                android:fontFamily="monospace"
                tools:text="28.0°C" />
        </LinearLayout>

        <!-- Voltage -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOLT"
                android:textColor="@color/textSecondary"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvVoltage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- V"
                android:textColor="@color/primaryEnergy"
                android:textSize="13sp"
                android:fontFamily="monospace"
                tools:text="4.20 V" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
