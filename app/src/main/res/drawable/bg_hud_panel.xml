<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC0B1020" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#40FFD54F" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="26dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="#80FFD54F" />
            <corners android:topLeftRadius="4dp" android:topRightRadius="4dp"
                android:bottomLeftRadius="0dp" android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
